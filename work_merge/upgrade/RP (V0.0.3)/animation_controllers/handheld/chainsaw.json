{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.mobblocks_chainsaw": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "first_person_hold": "c.is_first_person"
                        },
                        {
                            "third_person_hold": "!c.is_first_person"
                        }
                    ]
                },
                "first_person_hold": {
                    "animations": [
                        "first_person_hold"
                    ],
                    "transitions": [
                        {
                            "first_person_attack": "query.is_using_item"
                        },
                        {
                            "third_person_hold": "!c.is_first_person"
                        }
                    ]
                },
                "first_person_attack": {
                    "animations": [
                        "first_person_attack"
                    ],
                    "transitions": [
                        {
                            "first_person_hold": "query.any_animation_finished && !query.is_using_item"
                        },
                        {
                            "third_person_attack": "!c.is_first_person"
                        }
                    ]
                },
                "third_person_hold": {
                    "animations": [
                        "third_person_hold"
                    ],
                    "transitions": [
                        {
                            "third_person_attack": "query.is_using_item"
                        },
                        {
                            "first_person_hold": "c.is_first_person"
                        }
                    ]
                },
                "third_person_attack": {
                    "animations": [
                        "third_person_attack"
                    ],
                    "transitions": [
                        {
                            "third_person_hold": "query.any_animation_finished && !query.is_using_item"
                        },
                        {
                            "first_person_attack": "c.is_first_person"
                        }
                    ]
                }
            }
        }
    }
}