{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.mbl_ts.crow.move": {
      "initial_state": "default",
      "states": {
        "default": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "fly": "!q.is_on_ground"
            },
            {
              "walk": "q.is_moving && q.is_on_ground"
            }
          ],
          "blend_transition": 0.2
        },
        "walk": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "idle": "q.is_on_ground && !q.is_moving"
            },
            {
              "fly": "!q.is_on_ground"
            }
          ],
          "blend_transition": 0.2
        },
        "fly": {
          "animations": [
            "fly"
          ],
          "transitions": [
            {
              "idle": "q.is_on_ground && !q.is_moving"
            },
            {
              "walk": "q.is_moving && q.is_on_ground"
            }
          ],
          "blend_transition": 0.2
        },
        "idle": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "fly": "!q.is_on_ground"
            },
            {
              "walk": "q.is_moving && q.is_on_ground"
            }
          ],
          "blend_transition": 0.2
        }
      }
    }
  }
}