{
   "format_version":"1.10.0",
   "animation_controllers":{
      "controller.animation.zombie_walker":{
         "initial_state":"alive",
         "states":{
            "alive":{
               "animations":[
                  {
                     "idle":"query.modified_move_speed <= 0.1"
                  }
               ],
               "blend_transition":0.5,
               "blend_via_shortest_path":true,
               "transitions":[
                  {
                     "walking":"query.modified_move_speed > 0.1"
                  },
                  {
                     "corpse":"query.property('mbl_ts:body_type') == 'corpse'"
                  }
               ]
            },
            "walking":{
               "animations":[
                  "walking"
               ],
               "transitions":[
                  {
                     "alive":"query.modified_move_speed <= 0.1"
                  },
                  {
                     "corpse":"query.property('mbl_ts:body_type') == 'corpse'"
                  }
               ]
            },
            "corpse":{
               "animations":[
                  "corpse"
               ],
               "blend_transition":0.1,
               "blend_via_shortest_path":true
            }
         }
      },
      "controller.animation.zombie_walker_sniffing":{
         "initial_state":"default",
         "states":{
            "default":{
               "transitions":[
                  {
                     "sniffing":"query.is_sniffing"
                  }
               ]
            },
            "sniffing":{
               "animations":[
                  "sniffing"
               ],
               "transitions":[
                  {
                     "default":"!query.is_sniffing"
                  }
               ]
            }
         }
      }     
   }
}