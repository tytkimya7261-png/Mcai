{
   "format_version": "1.10.0",
   "minecraft:client_entity": {
      "description": {
         "identifier": "mbl_ts:nail_projectile",
         "materials": {
            "default": "entity_alphatest"
         },
         "textures": {
            "default": "textures/mobblocks/ts/items/handheld/nail_projectile"
         },
         "geometry": {
            "default": "geometry.nail_projectile"
         },
         "animations": {
            "move": "animation.mbl_nail.move"
         },
         "scripts": {
            "pre_animation": [
               "variable.shake = query.shake_time - query.frame_alpha;",
               "variable.shake_power = variable.shake > 0.0 ? -Math.sin(variable.shake * 200.0) * variable.shake : 0.0;"
            ],
            "animate": [
               "move"
            ]
         },
         "render_controllers": [
            "controller.render.default"
         ]
      }
   }
}
