{
   "format_version": "1.10.0",
   "minecraft:client_entity": {
      "description": {
         "identifier": "mbl_ts:bicycle",
         "materials": {
            "default": "entity_emissive_alpha"
         },
         "textures": {
            "default": "textures/mobblocks/ts/entity/bicycles/silver",
            "black": "textures/mobblocks/ts/entity/bicycles/black",
            "blue": "textures/mobblocks/ts/entity/bicycles/blue",
            "brown": "textures/mobblocks/ts/entity/bicycles/brown",
            "cyan": "textures/mobblocks/ts/entity/bicycles/cyan",
            "gray": "textures/mobblocks/ts/entity/bicycles/gray",
            "green": "textures/mobblocks/ts/entity/bicycles/green",
            "light_blue": "textures/mobblocks/ts/entity/bicycles/light_blue",
            "lime": "textures/mobblocks/ts/entity/bicycles/lime",
            "magenta": "textures/mobblocks/ts/entity/bicycles/magenta",
            "orange": "textures/mobblocks/ts/entity/bicycles/orange",
            "pink": "textures/mobblocks/ts/entity/bicycles/pink",
            "purple": "textures/mobblocks/ts/entity/bicycles/purple",
            "red": "textures/mobblocks/ts/entity/bicycles/red",
            "silver": "textures/mobblocks/ts/entity/bicycles/silver",
            "white": "textures/mobblocks/ts/entity/bicycles/white",
            "yellow": "textures/mobblocks/ts/entity/bicycles/yellow"
         },
         "geometry": {
            "default": "geometry.mbl_bicycle"
         },
         "animations": {
            "ride": "animation.mbl_bicycle.ride",
            "no_rider_no_wheels": "animation.mbl_bicycle.no_rider_no_wheels",
            "no_rider_wheels": "animation.mbl_bicycle.no_rider_wheels"
         },
         "scripts": {
            "animate": [
               {
                  "no_rider_no_wheels": "!query.property('mbl_ts:has_wheels')"
               },
               {
                  "no_rider_wheels": "!query.has_rider && query.property('mbl_ts:has_wheels')"
               },
               {
                  "ride": "query.has_rider && query.property('mbl_ts:has_wheels')"
               }
            ]
         },
         "render_controllers": [
            "controller.render.mbl_bicycle"
         ],
         "spawn_egg": {
            "texture": "bicycle"
         }
      }
   }
}