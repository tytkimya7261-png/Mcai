{
   "format_version": "1.10.0",
   "minecraft:client_entity": {
      "description": {
         "identifier": "mbl_ts:sedan_car",
         "materials": {
            "default": "entity_emissive_alpha"
         },
         "textures": {
            "default": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_white",
				"black": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_black",
				"blue": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_blue",
            "brown": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_brown",
				"cyan": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_cyan",
            "gray": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_gray",
				"green": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_green",
            "light_blue": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_light_blue",
				"light_gray": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_light_gray",
            "lime": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_lime",
				"magenta": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_magenta",
            "orange": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_orange",
				"pink": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_pink",
            "purple": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_purple",
				"red": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_red",
				"yellow": "textures/mobblocks/ts/entity/vehicles/sedan/sedan_yellow"
         },
         "geometry": {
            "default": "geometry.sedan_car"
         },
         "animations": {
            "car_tilt": "animation.sedan_car.tilt",
            "not_riding": "animation.sedan_car.not_riding",
            "wheels": "animation.sedan_car.wheels",
            "no_wheels": "animation.sedan_car.no_wheels",
            "no_engine": "animation.sedan_car.no_engine"
         },
                  "spawn_egg":{
               "texture":"sedan_vehcile_spawn_egg"
         },
         "scripts": {
            "animate": [
               {
                  "not_riding": "!query.has_rider"
               },
               {
                  "no_wheels": "query.property('mbl_ts:wheel_type') == 0"
               },
               {
                  "no_engine": "query.property('mbl_ts:engine_type') == 0"
               },
               "car_tilt",
               "wheels"
            ]
         },
         "render_controllers": [
            "controller.render.sedan_car"
         ]
      }
   }
}