{
	"format_version": "1.8.0",
	"animations": {
		"animation.bike_vehicle.no_wheels": {
			"loop": true,
			"bones": {
				"bike": {
					"position": [0, -2, 0]
				}
			}
		},
		"animation.bike_vehicle.wheels": {
			"loop": true,
			"bones": {
				"handlebars": {
					"rotation": [0, "math.clamp(query.yaw_speed, -30, 30)", 0]
				},
				"front_0": {
					"rotation": ["q.modified_distance_moved *9", "math.clamp(query.yaw_speed, -30, 30)", 0]
				},
				"back_0": {
					"rotation": ["q.modified_distance_moved *9", 0, 0]
				},
				"back_1": {
					"rotation": ["q.modified_distance_moved *9", 0, 0]
				},
				"front_1": {
					"rotation": ["q.modified_distance_moved *9", "math.clamp(query.yaw_speed, -30, 30)", 0]
				},
				"front_2": {
					"rotation": ["q.modified_distance_moved *9", "math.clamp(query.yaw_speed, -30, 30)", 0]
				},
				"back_2": {
					"rotation": ["q.modified_distance_moved *9", 0, 0]
				}
			}
		},
		"animation.bike_vehicle.tilt": {
			"loop": true,
			"bones": {
				"bike": {
					"rotation": ["Math.clamp(query.property('mbl_ts:positive_car_tilt') - query.property('mbl_ts:negative_car_tilt'), -45, 45)", 0, 0],
					"position": [
						0,
						"(query.property('mbl_ts:positive_car_tilt') == 0 && query.property('mbl_ts:negative_car_tilt') == 0) ? 0 : Math.clamp(query.property('mbl_ts:negative_car_tilt') * 0.5 - query.property('mbl_ts:positive_car_tilt') * 4.0, -7.8, -8.8)",
						0
					]
				}
			}
		}
	}
}