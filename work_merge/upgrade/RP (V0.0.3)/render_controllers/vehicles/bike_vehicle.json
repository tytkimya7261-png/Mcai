{
   "format_version": "1.8.0",
   "render_controllers": {
      "controller.render.bike_vehicle": {
         "arrays": {
            "textures": {
               "Array.variants": [
                  "Texture.default"
               ]
            }
         },
         "geometry": "Geometry.default",
         "materials": [
            {
               "*": "Material.default"
            }
         ],
         "textures": [
            "Array.variants[query.variant]"
         ],
         "part_visibility": [
            {
               "bike": "q.variant != 1000",
               "body": "q.variant != 1000",
               "handlebars": "q.variant != 1000",
               "front_0": "query.property('mbl_ts:wheel_type') == 1",
               "front_1": "query.property('mbl_ts:wheel_type') == 2",
               "front_2": "query.property('mbl_ts:wheel_type') == 3",
               "back_0": "query.property('mbl_ts:wheel_type') == 1",
               "back_1": "query.property('mbl_ts:wheel_type') == 2",
               "back_2": "query.property('mbl_ts:wheel_type') == 3",
               "engine_1": "query.property('mbl_ts:engine_type') == 1",
               "engine_2": "query.property('mbl_ts:engine_type') == 2",
               "engine_3": "query.property('mbl_ts:engine_type') == 3"
            }
         ]
      }
   }
}