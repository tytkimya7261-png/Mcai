{
   "format_version": "1.21.0",
   "minecraft:entity": {
      "description": {
         "identifier": "mbl_ts:supply_crate_food",
         "spawn_category": "creature",
         "is_spawnable": false,
         "is_summonable": true
      },
      "component_groups": {
         "mbl_ts:grounded": {
            "minecraft:variant": {
               "value": 1
            }
         }
      },
      "components": {
         "minecraft:type_family": {
            "family": [
               "supply_crate"
            ]
         },
         "minecraft:collision_box": {
            "width": 1.0,
            "height": 1.0
         },
         "minecraft:health": {
            "value": 500,
            "max": 500
         },
         "minecraft:scale": {
            "value": 1.1
         },
         "minecraft:variant": {
            "value": 0
         },
         "minecraft:behavior.float": {
            "priority": 0
         },
         "minecraft:interact": {
            "interactions": [
               {}
            ]
         },
         "minecraft:damage_sensor": {
            "triggers": {
               "cause": "all",
               "deals_damage": false
            }
         },
         "minecraft:knockback_resistance": {
            "value": 100,
            "max": 100
         },
         "minecraft:physics": {},
         "minecraft:environment_sensor": {
            "triggers": [
               {
                  "filters": {
                     "test": "on_ground",
                     "subject": "self",
                     "operator": "!="
                  },
                  "event": "mbl_ts:not_grounded"
               },
               {
                  "filters": {
                     "test": "on_ground",
                     "subject": "self",
                     "operator": "=="
                  },
                  "event": "mbl_ts:is_grounded"
               }
            ]
         }
      },
      "events": {
         "mbl_ts:not_grounded": {
            "remove": {
               "component_groups": [
                  "mbl_ts:grounded"
               ]
            }
         },
         "mbl_ts:is_grounded": {
            "add": {
               "component_groups": [
                  "mbl_ts:grounded"
               ]
            }
         }
      }
   }
}