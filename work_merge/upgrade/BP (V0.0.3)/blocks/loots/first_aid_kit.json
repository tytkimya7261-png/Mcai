{
   "format_version":"1.21.50",
   "minecraft:block":{
      "description":{
         "identifier":"mbl_ts:first_aid_kit",
         "menu_category":{
            "category":"construction"
         },
         "traits":{
            "minecraft:placement_direction":{
               "enabled_states":[
                  "minecraft:cardinal_direction"
               ]
            }
         },
         "states":{
            "mbl_ts:stage":[
               0,
               1
            ]
         }
      },
      "permutations":[
         {
            "condition":"query.block_state('mbl_ts:stage')==0",
            "components":{
               "minecraft:material_instances":{
                  "*":{
                     "texture":"first_aid_kit",
                     "render_method":"alpha_test"
                  }
               },
               "minecraft:light_emission":1,
         "minecraft:destructible_by_mining": {
            "seconds_to_destroy": 2.5,
            "item_specific_speeds": [
               {
                  "item": {
                     "tags": "query.all_tags('minecraft:is_pickaxe') && query.any_tag('minecraft:stone_tier','minecraft:copper_tier','minecraft:wooden_tier')"
                  },
                  "destroy_speed": 1.0
               },
               {
                  "item": {
                     "tags": "query.all_tags('minecraft:is_pickaxe') && query.any_tag('minecraft:golden_tier','minecraft:iron_tier')"
                  },
                  "destroy_speed": 0.75
               },
               {
                  "item": {
                     "tags": "query.all_tags('minecraft:is_pickaxe','minecraft:diamond_tier')"
                  },
                  "destroy_speed": 0.25
               },
               {
                  "item": {
                     "tags": "query.all_tags('minecraft:is_pickaxe','minecraft:netherite_tier')"
                  },
                  "destroy_speed": 0.15
               }
            ]
         },
         "tag:stone_pick_diggable": {},
               "minecraft:geometry":"geometry.mbl_crate",
               "minecraft:selection_box":{
                  "origin":[
                     -8,
                     0,
                     -8
                  ],
                  "size":[
                     16,
                      7,
                     16
                  ]
               }
            }
         },
         {
            "condition":"query.block_state('mbl_ts:stage')==1",
            "components":{
               "minecraft:material_instances":{
                  "*":{
                     "texture":"first_aid_kit",
                     "render_method":"alpha_test"
                  }
               },
               "minecraft:light_emission":0,
               "minecraft:destructible_by_mining":{
                  "seconds_to_destroy":0.8
               },
               "minecraft:geometry":"geometry.crate_open",
               "minecraft:selection_box":{
                  "origin":[
                     -8,
                     0,
                     -8
                  ],
                  "size":[
                     16,
                      7,
                     16
                  ]
               }
            }
         },
         {
            "condition":"q.block_state('minecraft:cardinal_direction') == 'north' ",
            "components":{
               "minecraft:transformation":{
                  "rotation":[
                     0,
                     180,
                     0
                  ]
               }
            }
         },
         {
            "condition":"q.block_state('minecraft:cardinal_direction') == 'south' ",
            "components":{
               "minecraft:transformation":{
                  "rotation":[
                     0,
                     0,
                     0
                  ]
               }
            }
         },
         {
            "condition":"q.block_state('minecraft:cardinal_direction') == 'east' ",
            "components":{
               "minecraft:transformation":{
                  "rotation":[
                     0,
                     90,
                     0
                  ]
               }
            }
         },
         {
            "condition":"q.block_state('minecraft:cardinal_direction') == 'west' ",
            "components":{
               "minecraft:transformation":{
                  "rotation":[
                     0,
                     270,
                     0
                  ]
               }
            }
         }
      ],
      "components":{
         "minecraft:loot":"loot_tables/mobblocks/ts/blocks/metal.json",
         "minecraft:collision_box":true,
         "minecraft:light_dampening":0,
         "minecraft:custom_components":[
            "mbl_ts:opening"
         ]
      }
   }
}