{
   "format_version": "1.21.50",
   "minecraft:block": {
      "description": {
         "identifier": "mbl_ts:gravestone",
         "menu_category": {
            "category": "none",
            "group": "none",
            "is_hidden_in_commands": true
         },
         "traits": {
            "minecraft:placement_direction": {
               "enabled_states": [
                  "minecraft:cardinal_direction"
               ]
            }
         }
      },
      "permutations":[
         {
            "condition":"q.block_state('minecraft:cardinal_direction') == 'north' ",
            "components":{
               "minecraft:transformation":{
                  "rotation":[
                     0,
                     180,
                     0
                  ]
               }
            }
         },
         {
            "condition":"q.block_state('minecraft:cardinal_direction') == 'south' ",
            "components":{
               "minecraft:transformation":{
                  "rotation":[
                     0,
                     0,
                     0
                  ]
               }
            }
         },
         {
            "condition":"q.block_state('minecraft:cardinal_direction') == 'east' ",
            "components":{
               "minecraft:transformation":{
                  "rotation":[
                     0,
                     90,
                     0
                  ]
               }
            }
         },
         {
            "condition":"q.block_state('minecraft:cardinal_direction') == 'west' ",
            "components":{
               "minecraft:transformation":{
                  "rotation":[
                     0,
                     270,
                     0
                  ]
               }
            }
         }
      ],
      "components": {
         "minecraft:collision_box": {
            "origin": [
               -8,
               0,
               -8
            ],
            "size": [
               16,
               16,
               16
            ]
         },
         "minecraft:selection_box": {
            "origin": [
               -8,
               0,
               -8
            ],
            "size": [
               16,
               16,
               16
            ]
         },
         "minecraft:destructible_by_explosion": false,
         "minecraft:destructible_by_mining": {
            "seconds_to_destroy": 2.0,
            "item_specific_speeds": [
               {
                  "item": {
                     "tags": "query.all_tags('minecraft:is_axe') && query.any_tag('minecraft:copper_tier','minecraft:stone_tier','minecraft:wooden_tier')"
                  },
                  "destroy_speed": 1.0
               },
               {
                  "item": {
                     "tags": "query.all_tags('minecraft:is_axe') && query.any_tag('minecraft:gold_tier','minecraft:iron_tier')"
                  },
                  "destroy_speed": 0.4
               },
               {
                  "item": {
                     "tags": "query.all_tags('minecraft:is_axe') && query.any_tag('minecraft:diamond_tier')"
                  },
                  "destroy_speed": 0.35
               },
               {
                  "item": {
                 "tags": "query.all_tags('minecraft:is_axe') && query.any_tag('minecraft:netherite_tier')"
                  },
                  "destroy_speed": 0.15
               }
            ]
         },
         "tag:stone_axe_diggable": {},
         "tag:minecraft:is_axe_item_destructible": {
      },
         "minecraft:light_emission": 0,
         "minecraft:light_dampening": 0,
         "minecraft:loot": "loot_tables/mobblocks/ts/blocks/gravestone/gravestone.json",
         "minecraft:geometry": "geometry.mbl_gravestone",
         "minecraft:material_instances": {
            "*": {
               "texture": "gravestone",
               "render_method": "alpha_test"
            }
         }
      }
   }
}