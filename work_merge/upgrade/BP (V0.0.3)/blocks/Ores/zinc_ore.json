{
   "format_version": "1.21.40",
   "minecraft:block": {
      "description": {
         "identifier": "mbl_ts:zinc_ore",
         "menu_category": {
            "category": "construction"
			}
		},
      "components":{
            "minecraft:loot": "loot_tables/mobblocks/ts/ores/zinc_ore.json",
            "minecraft:destructible_by_mining": {
               "seconds_to_destroy": 5,
               "item_specific_speeds": [
                  {
                     "item": {
                        "tags": "query.all_tags('minecraft:is_pickaxe') && query.any_tag('minecraft:iron_tier','minecraft:golden_tier')"
                     },
                     "destroy_speed": 1.0
                  },
                  {
                     "item": {
                        "tags": "query.all_tags('minecraft:is_pickaxe') && query.any_tag('minecraft:copper_tier','minecraft:iron_tier')"
                     },
                     "destroy_speed": 0.75
                  },
                  {
                     "item": {
                        "tags": "query.all_tags('minecraft:is_pickaxe','minecraft:diamond_tier')"
                     },
                     "destroy_speed": 0.5
                  },
                  {
                     "item": {
                        "tags": "query.all_tags('minecraft:is_pickaxe','minecraft:netherite_tier')"
                     },
                     "destroy_speed": 0.25
                  }
               ]
            },
            "tag:stone_pick_diggable": {},
            "tag:minecraft:is_pickaxe_item_destructible": {},
            "minecraft:light_emission": 0,
            "minecraft:material_instances": {
               "*": {
                  "texture": "zinc_ore",
                  "render_method": "alpha_test"
               }
            },
            "minecraft:geometry": "geometry.block_generic"
         }
      }
   }