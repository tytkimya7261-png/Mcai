
{
   "format_version": "1.21.0",
   "minecraft:block": {
      "description": {
         "identifier": "mbl_ts:apple_block",
         "states": {
            "mbl_ts:stage": [
               0,
               1,
               2
            ]
         }
      },
      "permutations": [
         {
            "condition": "query.block_state('mbl_ts:stage')==0",
            "components": {
               "minecraft:material_instances": {
                  "*": {
                     "texture": "apple_block_1",
                     "render_method": "alpha_test"
                  }
               },
               "minecraft:loot": "loot_tables/mobblocks/ts/blocks/plants/apple/stage_1.json",
               "minecraft:selection_box": {
                  "origin": [
                     -4,
                     0,
                     -4
                  ],
                  "size": [
                     8,
                     8,
                     8
                  ]
               }
            }
         },
         {
            "condition": "query.block_state('mbl_ts:stage')==1",
            "components": {
               "minecraft:material_instances": {
                  "*": {
                     "texture": "apple_block_2",
                     "render_method": "alpha_test"
                  }
               },
               "minecraft:loot": "loot_tables/mobblocks/ts/blocks/plants/apple/stage_2.json",
               "minecraft:selection_box": {
                  "origin": [
                     -4,
                     0,
                     -4
                  ],
                  "size": [
                     8,
                     8,
                     8
                  ]
               }
            }
         },
         {
            "condition": "query.block_state('mbl_ts:stage')==2",
            "components": {
               "minecraft:material_instances": {
                  "*": {
                     "texture": "apple_block_3",
                     "render_method": "alpha_test"
                  }
               },
               "minecraft:loot": "loot_tables/mobblocks/ts/blocks/plants/apple/stage_3.json",
               "minecraft:selection_box": {
                  "origin": [
                     -4,
                     0,
                     -4
                  ],
                  "size": [
                     8,
                     8,
                     8
                  ]
               }
            }
         }
      ],
      "components": {
         "minecraft:geometry": "geometry.apple_block",
         "minecraft:collision_box": false,
         "minecraft:light_dampening": 0,
         "minecraft:custom_components": [
            "mbl_ts:apple_block"
         ],
         "minecraft:tick": {
            "interval_range": [
               100,
               100
            ]
         }
      }
   }
}