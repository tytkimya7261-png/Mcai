{
  "format_version": "1.19.40",
  "minecraft:feature_rules": {
    "description": {
      "identifier": "mbl_ts:caravan_forest_spawn_rule",
      "places_feature": "mbl_ts:caravan_forest_structure"
    },
    "conditions": {
      "placement_pass": "surface_pass",
      "minecraft:biome_filter": {
        "any_of": [
          {
            "test": "has_biome_tag",
            "operator": "==",
            "value": "flower_forest"
          },
          {
            "test": "has_biome_tag",
            "operator": "==",
            "value": "cherry_grove"
          },
          {
            "test": "has_biome_tag",
            "operator": "==",
            "value": "jungle_edge"
          },
          {
            "test": "has_biome_tag",
            "operator": "==",
            "value": "birch"
          }
        ]
      }
    },
    "distribution": {
      "iterations": 1,
      "coordinate_eval_order": "xzy",
      "x": {
        "distribution": "uniform",
        "extent": [
          0,
          16
        ]
      },
      "y": "math.max(60, math.min(160, query.heightmap(variable.worldx, variable.worldz)))",
      "z": {
        "distribution": "uniform",
        "extent": [
          0,
          16
        ]
      },
      "scatter_chance": {
        "numerator": 1,
        "denominator": 500
      }
    }
  }
}