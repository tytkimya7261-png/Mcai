{
   "format_version":"1.13.0",
   "minecraft:feature_rules":{
      "description":{
         "identifier":"mbl_ts:overworld_underground_shale_oil",
         "places_feature":"mbl_ts:shale_oil_feature"
      },
		"conditions": {
			"placement_pass": "underground_pass",
			"minecraft:biome_filter": [
				// Scatter the ore throughout the Overworld
				{
					"any_of": [
						{
							"test": "has_biome_tag",
							"operator": "==",
							"value": "overworld"
						},
						{
							"test": "has_biome_tag",
							"operator": "==",
							"value": "overworld_generation"
						}
					]
				}
			]
		},
		"distribution": {
			"iterations": 1, // Placement attempts of the cluster, not the ore blocks
			"coordinate_eval_order": "zyx",
			"x": {
				"distribution": "uniform",
				"extent": [0, 16]
			},
			"y": {
				"distribution": "uniform", // You can use "triangle" to make ores more common in the middle of the extent
				"extent": [
					30, // Minimum y level for the ore to generate
					60 // Maximum y level for the ore to generate
				]
			},
			"z": {
				"distribution": "uniform",
				"extent": [0, 16]
			}
		}
	}
}
