{
  "format_version": "1.19.40",
  "minecraft:feature_rules": {
    "description": {
      "identifier": "mbl_ts:skyscraper_1_spawn_rule",
      "places_feature": "mbl_ts:skyscraper_1_structure"
    },
    "conditions": {
      "placement_pass": "surface_pass",
      "minecraft:biome_filter": {
        "any_of": [
          {
            "test": "has_biome_tag",
            "operator": "==",
            "value": "plains"
          },
          {
            "test": "has_biome_tag",
            "operator": "==",
            "value": "savanna"
          }
        ]
      }
    },
    "distribution": {
      "iterations": 1,
      "coordinate_eval_order": "xzy",
      "x": {
        "distribution": "uniform",
        "extent": [0, 16]
      },
      "y": "math.max(60, math.min(100, query.heightmap(variable.worldx, variable.worldz)))",
      "z": {
        "distribution": "uniform",
        "extent": [0, 16]
      },
      "scatter_chance": {
        "numerator": 1,
        "denominator": 1200
      }
    }
  }
}